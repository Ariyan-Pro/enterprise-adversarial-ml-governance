```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
pip-log.txt
pip-selfcheck.json

# Build and distribution artifacts
build/
dist/
*.egg
*.egg-info/
*.so

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
```